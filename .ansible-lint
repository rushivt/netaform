---
# Netaform Ansible Lint Configuration
# Tuned for: Multi-vendor network automation (Nokia SR Linux, FRRouting)

# Only lint Phase 4 Ansible content (avoid flagging earlier phases)
# Remove or adjust this if you want repo-wide linting
exclude_paths:
  - .github/
  - venv/
  - .venv/
  - phase-01-branch-office/
  - phase-02-ansible-automation/
  - phase-03-programmability/
  - scripts/

# Rules to skip
skip_list:
  # Network automation commonly uses raw/command/shell modules
  # because network devices don't have standard Ansible modules for everything
  - command-instead-of-module    # We use raw module for Alpine hosts
  - no-changed-when              # Network commands don't report change status cleanly
  - yaml[truthy]                 # Handled by .yamllint instead
  - name[missing]                # Some task files use short-form names
  - risky-shell-pipe             # Bootstrap scripts use pipes intentionally
  - jinja[spacing]               # Network config templates have tight formatting

# Warn but don't fail on these
warn_list:
  - experimental
  - fqcn[action-core]            # Warn about non-FQCN module names
