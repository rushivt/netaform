hostname edge-1
!
interface Ethernet1
   no switchport
   ip address 203.0.113.2/30
!
interface Ethernet2
   no switchport
   ip address 10.0.1.1/30
!
interface Ethernet3
   no switchport
   ip address 10.0.1.5/30
!
interface Loopback0
   ip address 10.0.255.10/32
!
ip routing
!
router bgp 65001
   router-id 10.0.255.10
   neighbor 203.0.113.1 remote-as 65000
   !
   address-family ipv4
      neighbor 203.0.113.1 activate
      redistribute ospf
!
router ospf 1
   router-id 10.0.255.10
   network 10.0.1.0/30 area 0
   network 10.0.1.4/30 area 0
   network 10.0.255.10/32 area 0
   default-information originate
!
